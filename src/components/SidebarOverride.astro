---
import Default from '@astrojs/starlight/components/Sidebar.astro';

// Starlight stores the sidebar tree in Astro.locals now, not in Astro.props
const { sidebar } = Astro.locals.starlightRoute;

// Helper to check if a group or its children are currently active
function isCurrentGroup(entry: any): boolean {
  if (entry.type === 'link') return entry.isCurrent;
  if (entry.type === 'group') return entry.entries.some(isCurrentGroup);
  return false;
}

// Locate the global "Posts" group
const postsGroup = sidebar.find((s: any) => s.type === 'group' && s.label === 'Posts');

if (postsGroup && postsGroup.type === 'group') {
  const activePostEntry = postsGroup.entries.find(isCurrentGroup);
  if (activePostEntry) {
    // Override the global sidebar for this route BEFORE rendering the Default sidebar
    Astro.locals.starlightRoute.sidebar = [activePostEntry];
  }
}
---
<Default {...Astro.props} />
