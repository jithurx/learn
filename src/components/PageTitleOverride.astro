---
import Default from '@astrojs/starlight/components/PageTitle.astro';

const { entry } = Astro.props;
const data = entry?.data || {};
---
<Default {...Astro.props} />

{data.number && (
  <div class="custom-actions">
    {data.slides && <a href={data.slides}>📄 Notes/Slides</a>}
    {data.pptx && <a href={data.pptx} download>📊 PPT</a>}
    {data.repo && <a href={data.repo}>🔗 GitHub</a>}
    {data.codeZip && <a href={data.codeZip} download>💻 Code</a>}
    {data.recording && <a href={data.recording}>📹 Recording</a>}
  </div>
)}

<style>
.custom-actions {
  display: flex; gap: 0.75rem; flex-wrap: wrap; margin: 1rem 0;
}
.custom-actions a {
  padding: 0.4rem 0.8rem; border: 1px solid var(--sl-color-gray-5); border-radius: 6px;
  text-decoration: none; font-size: 0.9rem; color: var(--sl-color-white);
}
.custom-actions a:hover {
  background-color: var(--sl-color-gray-6);
}
</style>
